<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>E-Tabungan Siswa</title>
  <!-- Tailwind CSS & FontAwesome -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans min-h-screen">

  <!-- NAVBAR -->
  <nav class="bg-green-700 text-white shadow-md p-4">
    <div class="container mx-auto flex justify-between items-center">
      <h1 class="text-xl font-bold flex items-center gap-2">
        <i class="fas fa-wallet"></i> E-Tabungan Madrasah (GitHub)
      </h1>
      <span id="namaAdmin" class="text-sm bg-green-800 px-3 py-1 rounded-full font-medium">Admin Panel</span>
    </div>
  </nav>

  <!-- MAIN CONTAINER -->
  <main class="container mx-auto p-4 max-w-6xl">
    
    <!-- TOTAL KAS CARD -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6 border border-gray-100 flex justify-between items-center">
      <div>
        <p class="text-gray-500 text-sm font-medium">Total Kas Tabungan</p>
        <h2 id="totalUangKeseluruhan" class="text-3xl font-black text-green-700 mt-1">Rp 0</h2>
      </div>
      <div class="p-4 bg-green-50 text-green-700 rounded-full text-2xl">
        <i class="fas fa-money-bill-wave"></i>
      </div>
    </div>

    <!-- TABEL DATA SISWA -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="p-4 bg-gray-50 border-b border-gray-100 flex justify-between items-center">
        <h3 class="font-bold text-gray-700">Daftar Tabungan Siswa</h3>
        <button onclick="muatDataOtomatis()" class="bg-green-600 hover:bg-green-700 text-white text-xs px-3 py-1.5 rounded-lg transition font-medium">
          <i class="fas fa-sync animate-spin-slow"></i> Sync Data
        </button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-100 text-gray-600 text-xs uppercase font-semibold">
              <th class="px-4 py-3">ID</th>
              <th class="px-4 py-3">Nama Siswa</th>
              <th class="px-4 py-3">No. WA</th>
              <th class="px-4 py-3 text-right">Saldo</th>
              <th class="px-4 py-3 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody id="tableDataSiswa" class="divide-y divide-gray-100">
            <tr>
              <td colspan="5" class="text-center py-6 text-gray-400 text-sm">Klik tombol Sync Data di atas untuk memuat data...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <!-- LOADING MODAL -->
  <div id="loader" class="fixed inset-0 bg-black/40 backdrop-blur-xs flex items-center justify-center hidden z-50">
    <div class="bg-white p-6 rounded-2xl shadow-xl flex flex-col items-center gap-3">
      <div class="w-10 h-10 border-4 border-green-700 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-sm font-semibold text-gray-700">Menghubungkan ke Google Sheets...</p>
    </div>
  </div>

  <!-- JAVASCRIPT GLOBAL -->
  <script>
    // TENTUKAN ALAMAT BACKEND GOOGLE SCRIPT LU DISINI!
    const API_URL = "https://script.google.com/macros/s/AKfycbypJgs4tB3-8WyBUuGCjSvWukkVMRBhtA_DR8f24AMJqjVqCiJBJrbYfhocJbrEzr0/exec";
    
    window.semuaTransaksi = []; 
    let idSekolahAktif = "SCH01"; // Sesuaikan dengan ID Sekolah lu di database

    function formatRp(angka) {
      return "Rp " + parseFloat(angka).toLocaleString('id-ID');
    }

    function showLoader(visible) {
      const loader = document.getElementById('loader');
      if (visible) loader.classList.remove('hidden');
      else loader.classList.add('hidden');
    }

    // 1. FUNGSI SYNC DATA DARI GOOGLE SHEETS
    async function muatDataOtomatis() {
      showLoader(true);
      try {
        // Ambil Data Siswa & Saldo Akhir
        let responSiswa = await fetch(`${API_URL}?action=getSiswaAdmin&idSekolah=${idSekolahAktif}`);
        let dataSiswa = await responSiswa.json();
        
        // Ambil Data Riwayat Transaksi (Untuk Struk Cetak)
        let responTrx = await fetch(`${API_URL}?action=getTransaksiAdmin&idSekolah=${idSekolahAktif}`);
        window.semuaTransaksi = await responTrx.json();

        let html = '';
        let totalKas = 0;

        if(dataSiswa && dataSiswa.length > 0) {
          dataSiswa.forEach(s => {
            const saldoSiswa = parseFloat(s.saldo) || 0;
            totalKas += saldoSiswa;
            const pesanWA = encodeURIComponent(`Assalamu'alaikum, info saldo tabungan Ananda *${s.namaSiswa}* saat ini adalah *${formatRp(saldoSiswa)}*`);
            const linkWA = `https://wa.me/${s.wa}?text=${pesanWA}`;

            html += `
              <tr class="hover:bg-green-50/50 transition text-sm">
                <td class="px-4 py-3 text-gray-400 font-medium">${s.idSiswa}</td>
                <td class="px-4 py-3 font-bold text-gray-800">${s.namaSiswa}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">${s.wa}</td>
                <td class="px-4 py-3 text-right font-black text-green-700">${formatRp(saldoSiswa)}</td>
                <td class="px-4 py-3 text-center">
                  <div class="flex justify-center gap-1">
                    <button onclick="downloadRekapSiswa('${s.idSiswa}', '${s.namaSiswa}')" class="w-8 h-8 bg-blue-500 text-white rounded-lg hover:bg-blue-600 shadow-sm flex items-center justify-center transition active:scale-90" title="Cetak Rekap">
                      <i class="fas fa-file-invoice"></i>
                    </button>
                    <a href="${linkWA}" target="_blank" class="w-8 h-8 bg-green-500 text-white rounded-lg hover:bg-green-600 shadow-sm flex items-center justify-center transition active:scale-90" title="Kirim WA">
                      <i class="fab fa-whatsapp"></i>
                    </a>
                  </div>
                </td>
              </tr>`;
          });
          document.getElementById('totalUangKeseluruhan').innerText = formatRp(totalKas);
          document.getElementById('tableDataSiswa').innerHTML = html;
        } else {
          document.getElementById('tableDataSiswa').innerHTML = `<tr><td colspan="5" class="text-center py-4 text-gray-500">Tidak ada data siswa ditemukan.</td></tr>`;
        }
      } catch (err) {
        alert("Gagal sinkronisasi data backend: " + err.message);
      } finally {
        showLoader(false);
      }
    }

    // 2. FUNGSI CETAK REKAP MANDIRI
    function downloadRekapSiswa(idSiswa, namaSiswa) {
      const trx = window.semuaTransaksi;

      if (!trx || trx.length === 0) {
        alert("Data transaksi kosong. Silakan klik tombol 'Sync Data' terlebih dahulu!");
        return;
      }

      const dataSantri = trx.filter(item => String(item.idSiswa) === String(idSiswa));
      if (dataSantri.length === 0) {
        alert("Tidak ada riwayat tabungan untuk siswa bernama: " + namaSiswa);
        return;
      }

      const win = window.open('', '_blank');
      let baris = '';
      let totalM = 0; let totalK = 0;

      dataSantri.forEach(t => {
        const m = parseFloat(t.setor || 0);
        const k = parseFloat(t.tarik || 0);
        totalM += m; totalK += k;
        baris += `
          <tr>
            <td style="border:1px solid #ccc;padding:8px">${t.tanggal}</td>
            <td style="border:1px solid #ccc;padding:8px;text-align:right">${m > 0 ? formatRp(m) : '-'}</td>
            <td style="border:1px solid #ccc;padding:8px;text-align:right">${k > 0 ? formatRp(k) : '-'}</td>
            <td style="border:1px solid #ccc;padding:8px;text-align:right;font-weight:bold">${formatRp(t.saldo)}</td>
          </tr>`;
      });

      const isi = `
        <html>
          <head>
            <title>Rekap - ${namaSiswa}</title>
            <style>
              body { font-family: sans-serif; padding: 20px; color: #333; }
              table { width: 100%; border-collapse: collapse; margin-top: 20px; }
              th { background: #f3f4f6; border: 1px solid #ccc; padding: 10px; }
              .header { text-align: center; border-bottom: 2px solid #166534; color: #166534; padding-bottom: 10px; }
              .footer { text-align: right; margin-top: 25px; border-top: 2px solid #eee; padding-top: 10px; }
            </style>
          </head>
          <body>
            <div class="header">
              <h2>REKAP HISTORI TABUNGAN: ${namaSiswa}</h2>
              <p>ID Anggota: ${idSiswa}</p>
            </div>
            <table>
              <thead>
                <tr>
                  <th>Tanggal Transaksi</th>
                  <th>Setor (M)</th>
                  <th>Tarik (K)</th>
                  <th>Saldo Berjalan</th>
                </tr>
              </thead>
              <tbody>${baris}</tbody>
            </table>
            <div class="footer">
              <p>Total Setoran: <b>${formatRp(totalM)}</b></p>
              <p>Total Penarikan: <b>${formatRp(totalK)}</b></p>
              <h3 style="color:#166534">Saldo Akhir Bersih: ${formatRp(totalM - totalK)}</h3>
            </div>
            <script>window.onload = function() { window.print(); };<\/script>
          </body>
        </html>`;

      win.document.write(isi);
      win.document.close();
    }

    // Otomatis tarik data saat halaman pertama kali dibuka admin
    window.onload = muatDataOtomatis;
  </script>
</body>
</html>
